generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id                String             @id @default(cuid())
  name              String
  email             String             @unique
  passwordHash      String?
  firstName         String?
  middleName        String?
  lastName          String?
  birthdate         DateTime?
  position          String?
  profilePictureUrl String?
  role              String
  headedDepartment  Department?        @relation("DepartmentHead")
  approvedRequests  ActivityRequest[]  @relation("ApprovedBy")
  requests          ActivityRequest[]  @relation("RequestedBy")
  approvals         RequestApproval[]
  auditLogs         AuditLog[]
  createdAt         DateTime           @default(now())
}

model Department {
  id        String           @id @default(cuid())
  name      String           @unique
  head      User?            @relation("DepartmentHead", fields: [headId], references: [id])
  headId    String?          @unique
  requests  ActivityRequest[]
}

model FundSource {
  id          String           @id @default(cuid())
  name        String           @unique
  description String?
  requests    ActivityRequest[]
}

model ActivityRequest {
  id                       String             @id @default(cuid())
  controlNumber            String             @unique
  date                     DateTime
  department               Department         @relation(fields: [departmentId], references: [id])
  departmentId             String
  requestedBy              User               @relation("RequestedBy", fields: [requestedById], references: [id])
  requestedById            String
  particulars              String
  preApprovalNotes         String?
  amount                   Decimal
  fundSource               FundSource?        @relation(fields: [fundSourceId], references: [id])
  fundSourceId             String?
  attachments              RequestAttachment[]
  approvals                RequestApproval[]
  auditLogs                AuditLog[]
  status                   String             @default("DRAFT")
  fundAvailable            Boolean?
  fundAvailabilityRemarks  String?
  reviewRemarks            String?
  endorsementRemarks       String?
  approvalRemarks          String?
  finalApprover            String?
  approvedBy              User?              @relation("ApprovedBy", fields: [approvedById], references: [id])
  approvedById             String?
  createdAt                DateTime           @default(now())
  updatedAt                DateTime           @updatedAt
}

model RequestAttachment {
  id         String   @id @default(cuid())
  request    ActivityRequest @relation(fields: [requestId], references: [id])
  requestId  String
  fileName   String
  fileUrl    String
  createdAt  DateTime @default(now())
}

model RequestApproval {
  id         String         @id @default(cuid())
  request    ActivityRequest @relation(fields: [requestId], references: [id])
  requestId  String
  actor      User           @relation(fields: [actorId], references: [id])
  actorId    String
  role       String
  action     String
  remarks    String?
  createdAt  DateTime       @default(now())
}

model AuditLog {
  id         String           @id @default(cuid())
  request    ActivityRequest? @relation(fields: [requestId], references: [id])
  requestId  String?
  user       User?            @relation(fields: [userId], references: [id])
  userId     String?
  action     String
  details    String?
  createdAt  DateTime         @default(now())
}
